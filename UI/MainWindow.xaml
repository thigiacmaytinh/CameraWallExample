<Window x:Class="WpfCameraWall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfCameraWall"
        Title="WPF D3D11 Camera Wall"
        Width="1600"
        Height="900"
        MinWidth="1000"
        MinHeight="600"
        Background="#202328">
    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3A3F45"/>
            <Setter Property="BorderBrush" Value="#626870"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="HoverToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="#2C3137"/>
            <Setter Property="BorderBrush" Value="#59616A"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Grid.RowSpan="2"
                Background="#2B2F35"
                BorderBrush="#15171A"
                BorderThickness="0,0,1,0"
                Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Cameras"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Drag a camera to a cell, or select a cell and double-click a camera."
                               Foreground="#BFC7D5"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <TextBlock Text="Add camera" Foreground="#D8D8D8" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBox x:Name="TxtCameraName" Height="28" Margin="0,0,0,4" Text="New camera 1" />
                    <TextBox x:Name="TxtCameraUrl" Height="28" Margin="0,0,0,4" Text="rtsp://user:password@192.168.1.100:554/Streaming/Channels/101" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add" Width="72" Margin="0,0,6,0" Click="AddCamera_Click" />
                        <Button Content="Remove" Width="72" Click="RemoveCamera_Click" />
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="CameraList"
                         Background="#23272C"
                         BorderBrush="#424850"
                         Foreground="White"
                         PreviewMouseLeftButtonDown="CameraList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="CameraList_PreviewMouseMove"
                         MouseDoubleClick="CameraList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="▣"
                                           Foreground="#9CC8FF"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MainUrl}"
                                               Foreground="#89929D"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Grid.Row="0">
            <local:CameraWallHost x:Name="CameraWall" />

            <!-- Popup is a separate HWND, so it can appear above the native D3D11 HwndHost. -->
            <Popup x:Name="CellHoverPopup"
                   PlacementTarget="{Binding ElementName=CameraWall}"
                   Placement="Relative"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border x:Name="HoverToolbarBorder"
                        Height="34"
                        Background="#E8202429"
                        BorderBrush="#7B838D"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="6,2"
                        MouseEnter="HoverToolbar_MouseEnter"
                        MouseLeave="HoverToolbar_MouseLeave">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="HoverCameraName"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="HoverCellText"
                                       Foreground="#AEB6C0"
                                       FontSize="9"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="HoverPlayButton"
                                    Style="{StaticResource HoverToolbarButton}"
                                    Content="▶"
                                    ToolTip="Play / resume"
                                    Click="HoverPlay_Click"/>
                            <Button x:Name="HoverPauseButton"
                                    Style="{StaticResource HoverToolbarButton}"
                                    Content="Ⅱ"
                                    ToolTip="Pause"
                                    Click="HoverPause_Click"/>
                            <Button x:Name="HoverCaptureButton"
                                    Style="{StaticResource HoverToolbarButton}"
                                    Content="▣"
                                    ToolTip="Capture PNG"
                                    Click="HoverCapture_Click"/>
                            <Button x:Name="HoverStopButton"
                                    Style="{StaticResource HoverToolbarButton}"
                                    Content="■"
                                    ToolTip="Stop this cell"
                                    Click="HoverStop_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Popup>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="1">
            <Border Background="#202327"
                    BorderBrush="#333"
                    BorderThickness="0,1,0,0"
                    Height="42">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0">
                        <TextBlock x:Name="CurrentLayoutText"
                                   Foreground="White"
                                   Text="2x2-4"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  |  " Foreground="#69717B" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SelectedCellText"
                                   Foreground="#FF7770"
                                   Text="Cell: -"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  |  " Foreground="#69717B" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText"
                                   Foreground="#B9C1CB"
                                   Text="Ready"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnLayout"
                            DockPanel.Dock="Right"
                            Width="38"
                            Height="30"
                            Margin="4"
                            Click="LayoutButton_Click"
                            ToolTip="Window division"
                            Content="▦"
                            FontSize="18"/>

                    <Button Content="Stop all"
                            DockPanel.Dock="Right"
                            Width="74"
                            Height="28"
                            Margin="4"
                            Click="StopAll_Click"/>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0">
                        <Button Style="{StaticResource ToolbarButton}" Content="▶" ToolTip="Play selected camera in selected cell" Click="PlaySelected_Click"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Ⅱ" ToolTip="Pause selected cell" Click="PauseSelected_Click"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="■" ToolTip="Stop selected cell" Click="StopSelected_Click"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="▣" ToolTip="Capture selected cell" Click="CaptureSelected_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Popup x:Name="LayoutPopup"
                   PlacementTarget="{Binding ElementName=BtnLayout}"
                   Placement="Top"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Width="330"
                        Background="#15191D"
                        BorderBrush="#30363D"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="ⓘ  Select a window division type"
                                   Foreground="White"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Standard Window Division"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl x:Name="StandardLayoutItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="40" Height="34" Margin="3" Padding="0"
                                            Click="LayoutItem_Click"
                                            ToolTip="{Binding Name}"
                                            Background="#5A5D60"
                                            BorderBrush="#AAA">
                                        <Grid>
                                            <local:LayoutPreviewControl Layout="{Binding Layout}"
                                                                        Width="32" Height="26"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding WndSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Wide Window Division"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Margin="0,16,0,8"/>

                        <ItemsControl x:Name="WideLayoutItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="48" Height="34" Margin="3" Padding="0"
                                            Click="LayoutItem_Click"
                                            ToolTip="{Binding Name}"
                                            Background="#5A5D60"
                                            BorderBrush="#AAA">
                                        <Grid>
                                            <local:LayoutPreviewControl Layout="{Binding Layout}"
                                                                        Width="40" Height="26"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding WndSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Custom Window Division"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Margin="0,16,0,8"/>

                        <ItemsControl x:Name="CustomLayoutItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="48" Height="34" Margin="3" Padding="0"
                                            Click="LayoutItem_Click"
                                            ToolTip="{Binding Name}"
                                            Background="#5A5D60"
                                            BorderBrush="#AAA">
                                        <Grid>
                                            <local:LayoutPreviewControl Layout="{Binding Layout}"
                                                                        Width="32" Height="26"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding WndSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="#2D3338" Margin="0,12,0,8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+ Add" Width="70" Height="28" Margin="4" Click="AddCustom_Click"/>
                            <Button Content="Edit" Width="70" Height="28" Margin="4" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
